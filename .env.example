# Shopify App credentials (from Partners Dashboard)
SHOPIFY_API_KEY=your_api_key_here
SHOPIFY_API_SECRET=your_api_secret_here
SHOPIFY_SCOPES=read_products,read_orders,read_customers,write_customers

# App URL (use ngrok for development)
HOST=https://your-app.ngrok-free.app
PORT=3000

# Database
DATABASE_URL="file:./dev.db"

# Email (SMTP - use SendGrid, Mailgun, or similar)
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key

# Email sender
EMAIL_FROM=noreply@your-domain.com
EMAIL_FROM_NAME=ReStock Reminder
